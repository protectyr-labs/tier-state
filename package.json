{
  "name": "@protectyr-labs/tier-state",
  "version": "1.0.0",
  "description": "Subscription tier resolution with trial state machine. 5-case trial logic, inline expiry, async + sync variants.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "src", "LICENSE"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["subscription", "tier", "trial", "state-machine", "saas", "billing"],
  "author": "Protectyr Labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/protectyr-labs/tier-state.git"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
